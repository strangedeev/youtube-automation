# ── Dependencies ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Secrets & credentials (NEVER commit) ──
.env
.env.local
.env.production
config/credentials.json
config/tokens.json
config/topics.json
config/*.key
config/*.pem
*.key
*.pem
*.cert
*.crt

# ── Generated content & runtime data ──
data/
uploads/
temp/
tmp/
logs/
*.log
*.db
*.sqlite
*.db-journal
*.db-shm
*.db-wal

# ── Large binaries (downloaded during setup) ──
models/
*.mp4
*.mp3
*.wav
*.webm
*.mkv
*.mov
*.avi

# ── Generated images (keep bundled fonts/assets) ──
*.jpg
*.jpeg
*.png
*.gif
!assets/**

# ── OS / editor noise ──
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# ── Build / cache ──
dist/
build/
coverage/
.nyc_output/
.cache/
*.cache
*.backup
*.bak

# Knowledge-graph cache (graphify)
graphify-out/

